# ========================================
# TL-STREAM — CONFIGURAÇÃO
# ========================================
# Copie as variáveis do .env principal do NebulaFTP

# ============= TELEGRAM =============
API_ID=
API_HASH=
BOT_TOKEN=

# ID do canal onde os chunks estão armazenados
CHAT_ID=

# ============= MONGODB =============
# Use o mesmo URI do NebulaFTP
# Dentro do Docker Compose: mongodb://mongo:27017
MONGODB=mongodb://mongo:27017
