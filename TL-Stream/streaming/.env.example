# ========================================
# TL-STREAM — CONFIGURAÇÃO
# ========================================
# Copie as variáveis do .env principal do TLFTPBot

# ============= TELEGRAM =============
API_ID=
API_HASH=
BOT_TOKEN=

# ID do canal onde os chunks estão armazenados
CHAT_ID=

# ============= MONGODB =============
# Deixe vazio para usar MongoDB local
# Preencha com a URI do MongoDB Atlas para usar banco na nuvem
MONGODB_CLOUD_URI=

# ============= FILTRO =============
# Pasta do banco a ser exposta (campo "parent" no MongoDB)
# Deixe vazio para expor tudo
ALLOWED_FOLDER=